<Page
    x:Class="WalkerMediaManager.UI.Views.CollectionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="40" RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="6">
            <TextBlock
                Text="Collections"
                Style="{ThemeResource TitleTextBlockStyle}" />

            <TextBlock
                Text="Track franchises, series, and themed collections."
                Style="{ThemeResource SubtitleTextBlockStyle}" />
        </StackPanel>

        <Border
            Grid.Row="1"
            Padding="20"
            CornerRadius="10"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1">

            <StackPanel Spacing="16">
                <TextBlock
                    x:Name="FormTitleText"
                    Text="Add Collection"
                    FontSize="22"
                    FontWeight="SemiBold" />

                <Grid
                    ColumnSpacing="12"
                    RowSpacing="12">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBox
                        x:Name="NameBox"
                        Header="Collection Name"
                        PlaceholderText="Mission: Impossible" />

                    <TextBox
                        x:Name="OwnedCountBox"
                        Grid.Column="1"
                        Header="Titles Owned"
                        PlaceholderText="6"
                        InputScope="Number" />

                    <TextBox
                        x:Name="TargetCountBox"
                        Grid.Column="2"
                        Header="Total Titles"
                        PlaceholderText="8"
                        InputScope="Number" />
                </Grid>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox
                        x:Name="DescriptionBox"
                        Header="Description"
                        PlaceholderText="Optional notes about this collection" />

                    <Button
                        x:Name="SaveButton"
                        Grid.Column="1"
                        Content="Add Collection"
                        Padding="22,10"
                        VerticalAlignment="Bottom"
                        Click="SaveButton_Click" />

                    <Button
                        x:Name="CancelButton"
                        Grid.Column="2"
                        Content="Cancel"
                        Padding="18,10"
                        VerticalAlignment="Bottom"
                        Visibility="Collapsed"
                        Click="CancelButton_Click" />
                </Grid>

                <InfoBar
                    x:Name="StatusInfoBar"
                    IsOpen="False"
                    IsClosable="True" />
            </StackPanel>
        </Border>

        <Grid
            Grid.Row="2"
            RowSpacing="12">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock
                x:Name="CollectionCountText"
                Text="0 collections"
                FontSize="20"
                FontWeight="SemiBold" />

            <ListView
                x:Name="CollectionsListView"
                Grid.Row="1"
                ItemsSource="{x:Bind Collections, Mode=OneWay}"
                SelectionMode="None">

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="0,0,0,12"
                            Padding="20"
                            CornerRadius="10"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">

                            <Grid ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="5">
                                    <TextBlock
                                        Text="{Binding Name}"
                                        FontSize="20"
                                        FontWeight="SemiBold" />

                                    <TextBlock
                                        Text="{Binding Description}"
                                        TextWrapping="Wrap"
                                        Opacity="0.65" />

                                    <TextBlock
                                        Text="{Binding MissingDisplay}"
                                        Opacity="0.75" />
                                </StackPanel>

                                <StackPanel
                                    Grid.Column="1"
                                    Spacing="5"
                                    VerticalAlignment="Center">

                                    <TextBlock
                                        Text="{Binding ProgressDisplay}"
                                        FontWeight="SemiBold" />

                                    <TextBlock
                                        Text="{Binding CompletionDisplay}"
                                        Opacity="0.7" />
                                </StackPanel>

                                <Button
                                    Grid.Column="2"
                                    Content="Edit"
                                    Tag="{Binding}"
                                    Click="EditButton_Click" />

                                <Button
                                    Grid.Column="3"
                                    Content="Delete"
                                    Tag="{Binding}"
                                    Click="DeleteButton_Click" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>