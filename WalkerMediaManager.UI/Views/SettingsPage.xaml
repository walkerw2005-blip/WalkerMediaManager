<Page
    x:Class="WalkerMediaManager.UI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="40" Spacing="24">

            <StackPanel Spacing="6">
                <TextBlock
                    Text="Settings"
                    Style="{ThemeResource TitleTextBlockStyle}" />

                <TextBlock
                    Text="Configure Plex and Walker Media Manager."
                    Style="{ThemeResource SubtitleTextBlockStyle}" />
            </StackPanel>

            <Border
                Padding="24"
                CornerRadius="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">

                <StackPanel Spacing="18">
                    <TextBlock
                        Text="Plex Server"
                        FontSize="24"
                        FontWeight="SemiBold" />

                    <TextBlock
                        Text="Connect Walker Media Manager to your Plex Media Server. A typical local address is http://192.168.1.50:32400."
                        TextWrapping="Wrap"
                        Opacity="0.7" />

                    <TextBox
                        x:Name="ServerUrlBox"
                        Header="Server Address"
                        PlaceholderText="http://192.168.1.50:32400" />

                    <PasswordBox
                        x:Name="TokenBox"
                        Header="Plex Token"
                        PlaceholderText="Paste your X-Plex-Token" />

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button
                            x:Name="TestConnectionButton"
                            Content="Test Connection"
                            Padding="22,10"
                            Click="TestConnectionButton_Click" />

                        <Button
                            x:Name="SaveSettingsButton"
                            Content="Save Settings"
                            Padding="22,10"
                            Click="SaveSettingsButton_Click" />

                        <ProgressRing
                            x:Name="ConnectionProgressRing"
                            Width="28"
                            Height="28"
                            IsActive="False"
                            Visibility="Collapsed" />
                    </StackPanel>

                    <InfoBar
                        x:Name="ConnectionInfoBar"
                        IsOpen="False"
                        IsClosable="True" />
                </StackPanel>
            </Border>

            <Border
                Padding="24"
                CornerRadius="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">

                <StackPanel Spacing="16">
                    <TextBlock
                        Text="Plex Movie Sync"
                        FontSize="24"
                        FontWeight="SemiBold" />

                    <TextBlock
                        Text="Choose the Plex library that contains your movies, then import or refresh it. Existing local titles are matched by Plex ID or title and year."
                        TextWrapping="Wrap"
                        Opacity="0.7" />

                    <ComboBox
                        x:Name="MovieLibraryComboBox"
                        Header="Movie Library"
                        ItemsSource="{x:Bind MovieLibraries, Mode=OneWay}"
                        DisplayMemberPath="DisplayName"
                        PlaceholderText="Test the connection to discover libraries" />

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button
                            x:Name="SyncMoviesButton"
                            Content="Sync Movies from Plex"
                            Padding="22,10"
                            IsEnabled="False"
                            Click="SyncMoviesButton_Click" />

                        <ProgressRing
                            x:Name="MovieSyncProgressRing"
                            Width="28"
                            Height="28"
                            IsActive="False"
                            Visibility="Collapsed" />
                    </StackPanel>

                    <TextBlock
                        x:Name="MovieSyncProgressText"
                        TextWrapping="Wrap"
                        Opacity="0.7" />

                    <InfoBar
                        x:Name="MovieSyncInfoBar"
                        IsOpen="False"
                        IsClosable="True" />
                </StackPanel>
            </Border>

            <Border
                Padding="24"
                CornerRadius="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">

                <StackPanel Spacing="16">
                    <TextBlock
                        Text="Plex TV Show Sync"
                        FontSize="24"
                        FontWeight="SemiBold" />

                    <TextBlock
                        Text="Choose your Plex TV library to import or refresh every series. Existing local shows are matched by Plex ID or title and year."
                        TextWrapping="Wrap"
                        Opacity="0.7" />

                    <ComboBox
                        x:Name="TVLibraryComboBox"
                        Header="TV Library"
                        ItemsSource="{x:Bind TVLibraries, Mode=OneWay}"
                        DisplayMemberPath="DisplayName"
                        PlaceholderText="Test the connection to discover TV libraries" />

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button
                            x:Name="SyncTVShowsButton"
                            Content="Sync TV Shows from Plex"
                            Padding="22,10"
                            IsEnabled="False"
                            Click="SyncTVShowsButton_Click" />

                        <ProgressRing
                            x:Name="TVSyncProgressRing"
                            Width="28"
                            Height="28"
                            IsActive="False"
                            Visibility="Collapsed" />
                    </StackPanel>

                    <TextBlock
                        x:Name="TVSyncProgressText"
                        TextWrapping="Wrap"
                        Opacity="0.7" />

                    <InfoBar
                        x:Name="TVSyncInfoBar"
                        IsOpen="False"
                        IsClosable="True" />
                </StackPanel>
            </Border>

            <Border
                Padding="24"
                CornerRadius="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">

                <StackPanel Spacing="16">
                    <TextBlock
                        Text="Discovered Libraries"
                        FontSize="24"
                        FontWeight="SemiBold" />

                    <ListView
                        x:Name="LibrariesListView"
                        ItemsSource="{x:Bind Libraries, Mode=OneWay}"
                        SelectionMode="None">

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="0,0,0,8"
                                    Padding="14"
                                    CornerRadius="8"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1">

                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Text="{Binding Title}"
                                            FontSize="18"
                                            FontWeight="SemiBold" />

                                        <TextBlock
                                            Grid.Column="1"
                                            Text="{Binding Type}"
                                            Opacity="0.7" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
