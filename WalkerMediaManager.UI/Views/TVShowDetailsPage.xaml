<Page
    x:Class="WalkerMediaManager.UI.Views.TVShowDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <Grid Padding="32" RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="Back" Click="BackButton_Click" />
                <TextBlock Text="TV Show Details" Style="{ThemeResource TitleTextBlockStyle}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <Grid Grid.Row="1" ColumnSpacing="28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Height="390" CornerRadius="14"
                        Background="{ThemeResource ControlFillColorSecondaryBrush}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                        <FontIcon Glyph="&#xE714;" FontSize="72" Opacity="0.35" />
                        <TextBlock Text="Poster artwork" Opacity="0.6" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1" Spacing="14">
                    <TextBlock x:Name="TitleText" Text="TV Show" FontSize="36" FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="YearText" FontSize="20" Opacity="0.7" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Padding="10,5" CornerRadius="6"
                                Background="{ThemeResource ControlFillColorSecondaryBrush}">
                            <TextBlock x:Name="SeasonsText" />
                        </Border>
                        <Border Padding="10,5" CornerRadius="6"
                                Background="{ThemeResource ControlFillColorSecondaryBrush}">
                            <TextBlock x:Name="EpisodesText" />
                        </Border>
                    </StackPanel>
                    <TextBlock Text="Studio / Network" FontWeight="SemiBold" Margin="0,8,0,0" />
                    <TextBlock x:Name="StudioText" FontSize="18" />
                    <TextBlock Text="Summary" FontWeight="SemiBold" Margin="0,8,0,0" />
                    <TextBlock x:Name="SummaryText" TextWrapping="Wrap" FontSize="17"
                               MaxWidth="900" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2" ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Padding="18" CornerRadius="10"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Plex Information" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock x:Name="PlexStatusText" />
                        <TextBlock x:Name="PlexRatingKeyText" TextWrapping="Wrap" />
                        <TextBlock x:Name="PlexGuidText" TextWrapping="Wrap" />
                        <TextBlock x:Name="LastSyncedText" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Padding="18" CornerRadius="10"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <TextBlock Text="External IDs and Artwork" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock x:Name="IMDbText" TextWrapping="Wrap" />
                        <TextBlock x:Name="TMDbText" TextWrapping="Wrap" />
                        <TextBlock x:Name="PosterPathText" TextWrapping="Wrap" />
                        <TextBlock x:Name="BackgroundPathText" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <InfoBar x:Name="StatusInfoBar" Grid.Row="2" Margin="0,220,0,0"
                     IsOpen="False" IsClosable="True" />
        </Grid>
    </ScrollViewer>
</Page>
