<Page
    x:Class="WalkerMediaManager.UI.Views.WishlistPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="40" RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="6">
            <TextBlock
                Text="Wishlist"
                Style="{ThemeResource TitleTextBlockStyle}" />

            <TextBlock
                Text="Keep track of movies and television shows you want to buy."
                Style="{ThemeResource SubtitleTextBlockStyle}" />
        </StackPanel>

        <Border
            Grid.Row="1"
            Padding="20"
            CornerRadius="10"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1">

            <StackPanel Spacing="16">
                <TextBlock
                    x:Name="FormTitleText"
                    Text="Add Wishlist Item"
                    FontSize="22"
                    FontWeight="SemiBold" />

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox
                        x:Name="TitleBox"
                        Header="Title"
                        PlaceholderText="Enter a movie or TV-show title" />

                    <ComboBox
                        x:Name="PriorityComboBox"
                        Grid.Column="1"
                        Header="Priority"
                        SelectedIndex="1">

                        <ComboBoxItem
                            Content="Low"
                            Tag="1" />

                        <ComboBoxItem
                            Content="Normal"
                            Tag="2" />

                        <ComboBoxItem
                            Content="High"
                            Tag="3" />
                    </ComboBox>

                    <Button
                        x:Name="SaveButton"
                        Grid.Column="2"
                        Content="Add to Wishlist"
                        Padding="22,10"
                        VerticalAlignment="Bottom"
                        Click="SaveButton_Click" />

                    <Button
                        x:Name="CancelButton"
                        Grid.Column="3"
                        Content="Cancel"
                        Padding="18,10"
                        VerticalAlignment="Bottom"
                        Visibility="Collapsed"
                        Click="CancelButton_Click" />
                </Grid>

                <InfoBar
                    x:Name="StatusInfoBar"
                    IsOpen="False"
                    IsClosable="True" />
            </StackPanel>
        </Border>

        <Grid
            Grid.Row="2"
            RowSpacing="12">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock
                x:Name="WishlistCountText"
                Text="0 wishlist items"
                FontSize="20"
                FontWeight="SemiBold" />

            <ListView
                x:Name="WishlistListView"
                Grid.Row="1"
                ItemsSource="{x:Bind WishlistItems, Mode=OneWay}"
                SelectionMode="None">

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="0,0,0,10"
                            Padding="18"
                            CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Text="{Binding Title}"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    VerticalAlignment="Center" />

                                <TextBlock
                                    Grid.Column="1"
                                    Text="{Binding Priority}"
                                    VerticalAlignment="Center" />

                                <Button
                                    Grid.Column="2"
                                    Content="Mark Purchased"
                                    Tag="{Binding}"
                                    Click="MarkPurchasedButton_Click" />

                                <Button
                                    Grid.Column="3"
                                    Content="Edit"
                                    Tag="{Binding}"
                                    Click="EditButton_Click" />

                                <Button
                                    Grid.Column="4"
                                    Content="Remove"
                                    Tag="{Binding}"
                                    Click="RemoveButton_Click" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>