<Page
    x:Class="WalkerMediaManager.UI.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="40" Spacing="28">

            <StackPanel Spacing="6">
                <TextBlock
                    Text="Dashboard"
                    Style="{ThemeResource TitleTextBlockStyle}" />

                <TextBlock
                    Text="Your media collection at a glance."
                    Style="{ThemeResource SubtitleTextBlockStyle}" />
            </StackPanel>

            <Border
                Padding="24"
                CornerRadius="12"
                Background="{ThemeResource AccentFillColorDefaultBrush}">

                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <FontIcon
                        Glyph="&#xE7BF;"
                        FontSize="42"
                        VerticalAlignment="Center" />

                    <StackPanel
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Spacing="4">

                        <TextBlock
                            Text="Smart Buy"
                            FontSize="24"
                            FontWeight="SemiBold" />

                        <TextBlock
                            Text="Check whether you already own a title before buying it."
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <Button
                        Grid.Column="2"
                        Content="Open Smart Buy"
                        Padding="20,10"
                        VerticalAlignment="Center"
                        Click="OpenSmartBuy_Click" />
                </Grid>
            </Border>

            <StackPanel Spacing="14">
                <TextBlock
                    Text="Collection Overview"
                    Style="{ThemeResource SubtitleTextBlockStyle}"
                    FontWeight="SemiBold" />

                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Grid.Column="0"
                        Padding="20"
                        CornerRadius="10"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">

                        <StackPanel Spacing="8">
                            <FontIcon
                                Glyph="&#xE714;"
                                FontSize="28"
                                HorizontalAlignment="Left" />

                            <TextBlock
                                x:Name="MovieCountText"
                                Text="0"
                                FontSize="32"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="Movies"
                                Opacity="0.7" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="1"
                        Padding="20"
                        CornerRadius="10"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">

                        <StackPanel Spacing="8">
                            <FontIcon
                                Glyph="&#xE7F4;"
                                FontSize="28"
                                HorizontalAlignment="Left" />

                            <TextBlock
                                x:Name="TvSeriesCountText"
                                Text="0"
                                FontSize="32"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="TV Series"
                                Opacity="0.7" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="2"
                        Padding="20"
                        CornerRadius="10"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">

                        <StackPanel Spacing="8">
                            <FontIcon
                                Glyph="&#xE8F1;"
                                FontSize="28"
                                HorizontalAlignment="Left" />

                            <TextBlock
                                x:Name="OwnedTitleCountText"
                                Text="0"
                                FontSize="32"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="Owned Titles"
                                Opacity="0.7" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="3"
                        Padding="20"
                        CornerRadius="10"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">

                        <StackPanel Spacing="8">
                            <FontIcon
                                Glyph="&#xE8B7;"
                                FontSize="28"
                                HorizontalAlignment="Left" />

                            <TextBlock
                                Text="0"
                                FontSize="32"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="Wishlist Items"
                                Opacity="0.7" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Padding="24"
                    CornerRadius="10"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">

                    <StackPanel Spacing="16">
                        <TextBlock
                            Text="System Status"
                            FontSize="22"
                            FontWeight="SemiBold" />

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Local Database" />

                            <TextBlock
                                Grid.Column="1"
                                Text="Connected"
                                Opacity="0.7" />
                        </Grid>

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Plex Server" />

                            <TextBlock
                                Grid.Column="1"
                                Text="Not connected"
                                Opacity="0.7" />
                        </Grid>

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Metadata Provider" />

                            <TextBlock
                                Grid.Column="1"
                                Text="Not configured"
                                Opacity="0.7" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="24"
                    CornerRadius="10"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">

                    <StackPanel Spacing="16">
                        <TextBlock
                            Text="Collection Health"
                            FontSize="22"
                            FontWeight="SemiBold" />

                        <TextBlock Text="Possible Duplicates: 0" />
                        <TextBlock Text="Incomplete Collections: 0" />
                        <TextBlock Text="Missing Metadata: 0" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border
                Padding="24"
                CornerRadius="10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">

                <StackPanel Spacing="12">
                    <TextBlock
                        Text="Recent Activity"
                        FontSize="22"
                        FontWeight="SemiBold" />

                    <TextBlock
                        Text="No recent activity. Your Plex imports, purchases, and collection changes will appear here."
                        TextWrapping="Wrap"
                        Opacity="0.7" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>