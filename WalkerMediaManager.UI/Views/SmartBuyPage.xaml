<Page
    x:Class="WalkerMediaManager.UI.Views.SmartBuyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="40" RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="6">
            <TextBlock
                Text="Smart Buy"
                Style="{ThemeResource TitleTextBlockStyle}" />

            <TextBlock
                Text="Search before you buy and avoid duplicate purchases."
                Style="{ThemeResource SubtitleTextBlockStyle}" />
        </StackPanel>

        <Border
            Grid.Row="1"
            Padding="24"
            CornerRadius="12"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1">

            <StackPanel Spacing="16">
                <TextBlock
                    Text="What are you thinking about buying?"
                    FontSize="22"
                    FontWeight="SemiBold" />

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox
                        x:Name="SearchBox"
                        Header="Movie or TV-show title"
                        PlaceholderText="For example: Top Gun"
                        KeyDown="SearchBox_KeyDown" />

                    <Button
                        Grid.Column="1"
                        Content="Search"
                        Padding="26,10"
                        VerticalAlignment="Bottom"
                        Click="SearchButton_Click" />

                    <Button
                        Grid.Column="2"
                        Content="Clear"
                        Padding="18,10"
                        VerticalAlignment="Bottom"
                        Click="ClearButton_Click" />
                </Grid>

                <ProgressRing
                    x:Name="SearchProgressRing"
                    Width="28"
                    Height="28"
                    IsActive="False"
                    Visibility="Collapsed"
                    HorizontalAlignment="Left" />

                <InfoBar
                    x:Name="SearchInfoBar"
                    IsOpen="False"
                    IsClosable="True" />

                <Button
                    x:Name="AddToWishlistButton"
                    Content="Add Search to Wishlist"
                    Padding="22,10"
                    HorizontalAlignment="Left"
                    Visibility="Collapsed"
                    Click="AddToWishlistButton_Click" />
            </StackPanel>
        </Border>

        <Grid
            Grid.Row="2"
            RowSpacing="16">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Text="Search Results"
                    FontSize="22"
                    FontWeight="SemiBold" />

                <TextBlock
                    x:Name="ResultCountText"
                    Grid.Column="1"
                    Opacity="0.7"
                    VerticalAlignment="Center" />
            </Grid>

            <Grid Grid.Row="1">
                <StackPanel
                    x:Name="EmptyStatePanel"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12">

                    <FontIcon
                        Glyph="&#xE721;"
                        FontSize="48"
                        Opacity="0.55"
                        HorizontalAlignment="Center" />

                    <TextBlock
                        Text="Search your collection"
                        FontSize="22"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Center" />

                    <TextBlock
                        Text="Enter a movie or TV-show title to see whether you already own it."
                        TextWrapping="Wrap"
                        MaxWidth="500"
                        TextAlignment="Center"
                        Opacity="0.7" />
                </StackPanel>

                <ListView
                    x:Name="ResultsListView"
                    ItemsSource="{x:Bind Results, Mode=OneWay}"
                    SelectionMode="None"
                    Visibility="Collapsed">

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,0,0,12"
                                Padding="20"
                                CornerRadius="10"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">

                                <Grid ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Spacing="5">
                                        <TextBlock
                                            Text="{Binding Title}"
                                            FontSize="21"
                                            FontWeight="SemiBold" />

                                        <TextBlock
                                            Text="{Binding MediaType}"
                                            Opacity="0.75" />

                                        <TextBlock
                                            Text="{Binding Details}"
                                            Opacity="0.65" />
                                    </StackPanel>

                                    <StackPanel
                                        Grid.Column="1"
                                        Spacing="4"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Right">

                                        <FontIcon
                                            Glyph="&#xE73E;"
                                            FontSize="24"
                                            HorizontalAlignment="Center" />

                                        <TextBlock
                                            Text="{Binding OwnershipStatus}"
                                            FontWeight="SemiBold" />

                                        <TextBlock
                                            Text="Do not buy another copy"
                                            FontSize="12"
                                            Opacity="0.65" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>
    </Grid>
</Page>