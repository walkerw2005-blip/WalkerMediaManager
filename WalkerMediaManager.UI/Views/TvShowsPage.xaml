<Page
    x:Class="WalkerMediaManager.UI.Views.TvShowsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WalkerMediaManager.UI.Controls">

    <Grid Padding="32" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock Text="TV Shows" Style="{ThemeResource TitleTextBlockStyle}" />
                <TextBlock Text="Browse and manage your television collection."
                           Style="{ThemeResource SubtitleTextBlockStyle}" />
            </StackPanel>
            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                <TextBlock x:Name="ShowCountText" Text="0 TV shows" FontSize="22"
                           FontWeight="SemiBold" HorizontalAlignment="Right" />
                <TextBlock x:Name="VisibleCountText" Text="0 shown" Opacity="0.65"
                           HorizontalAlignment="Right" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Padding="16" CornerRadius="10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <AutoSuggestBox x:Name="SearchBox"
                                PlaceholderText="Search title, year, studio, or summary"
                                QueryIcon="Find" TextChanged="SearchBox_TextChanged" />
                <ComboBox x:Name="SortComboBox" Grid.Column="1" Header="Sort"
                          SelectionChanged="SortComboBox_SelectionChanged" SelectedIndex="0">
                    <ComboBoxItem Content="Title A–Z" Tag="TitleAscending" />
                    <ComboBoxItem Content="Title Z–A" Tag="TitleDescending" />
                    <ComboBoxItem Content="Newest first" Tag="YearDescending" />
                    <ComboBoxItem Content="Oldest first" Tag="YearAscending" />
                    <ComboBoxItem Content="Most seasons" Tag="SeasonsDescending" />
                    <ComboBoxItem Content="Most episodes" Tag="EpisodesDescending" />
                    <ComboBoxItem Content="Recently synced" Tag="RecentlySynced" />
                </ComboBox>
                <ToggleButton x:Name="GridViewToggle" Grid.Column="2" Content="Grid" IsChecked="True"
                              VerticalAlignment="Bottom" Click="GridViewToggle_Click" />
                <Button Grid.Column="3" Content="Add TV Show" VerticalAlignment="Bottom"
                        Click="ShowEditorButton_Click" />
            </Grid>
        </Border>

        <InfoBar x:Name="StatusInfoBar" Grid.Row="2" IsOpen="False" IsClosable="True" />

        <Grid Grid.Row="3">
            <GridView x:Name="ShowGridView" ItemsSource="{x:Bind DisplayShows, Mode=OneWay}"
                      SelectionMode="None" IsItemClickEnabled="False">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="0" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <controls:TVShowCard Show="{Binding}"
                                             OpenRequested="TVShowCard_OpenRequested"
                                             EditRequested="TVShowCard_EditRequested"
                                             DeleteRequested="TVShowCard_DeleteRequested" />
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <ListView x:Name="ShowListView" ItemsSource="{x:Bind DisplayShows, Mode=OneWay}"
                      SelectionMode="None" Visibility="Collapsed">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,8" Padding="14" CornerRadius="8"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" FontSize="17" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding StudioDisplay}" Opacity="0.65" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding YearDisplay}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="{Binding SeasonsDisplay}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="3" Text="{Binding EpisodesDisplay}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="4" Text="{Binding PlexStatus}" TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="5" Content="Open" Tag="{Binding}" Click="OpenShow_Click" />
                                <Button Grid.Column="6" Content="Edit" Tag="{Binding}" Click="EditShow_Click" />
                                <Button Grid.Column="7" Content="Delete" Tag="{Binding}" Click="DeleteShow_Click" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <ContentDialog x:Name="ShowEditorDialog" Title="Add TV Show" PrimaryButtonText="Save"
                       CloseButtonText="Cancel" PrimaryButtonClick="ShowEditorDialog_PrimaryButtonClick">
            <ScrollViewer MaxHeight="620">
                <StackPanel Spacing="12" MinWidth="520">
                    <TextBox x:Name="TitleBox" Header="Series title" />
                    <TextBox x:Name="YearBox" Header="Release year" InputScope="Number" />
                    <TextBox x:Name="SeasonsBox" Header="Seasons owned" InputScope="Number" />
                    <TextBox x:Name="EpisodesBox" Header="Episodes owned" InputScope="Number" />
                    <TextBox x:Name="StudioBox" Header="Studio / Network" />
                    <TextBox x:Name="SummaryBox" Header="Summary" AcceptsReturn="True"
                             TextWrapping="Wrap" MinHeight="110" />
                </StackPanel>
            </ScrollViewer>
        </ContentDialog>
    </Grid>
</Page>
