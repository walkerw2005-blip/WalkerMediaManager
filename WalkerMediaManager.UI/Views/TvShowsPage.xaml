<Page
    x:Class="WalkerMediaManager.UI.Views.TvShowsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="40" RowSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="6">
            <TextBlock
                Text="TV Shows"
                Style="{ThemeResource TitleTextBlockStyle}" />

            <TextBlock
                Text="Add and manage the television series you own."
                Style="{ThemeResource SubtitleTextBlockStyle}" />
        </StackPanel>

        <Border
            Grid.Row="1"
            Padding="20"
            CornerRadius="10"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1">

            <StackPanel Spacing="16">
                <TextBlock
                    x:Name="FormTitleText"
                    Text="Add TV Show"
                    FontSize="22"
                    FontWeight="SemiBold" />

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox
                        x:Name="TitleBox"
                        Header="Series Title"
                        PlaceholderText="Enter TV series title" />

                    <TextBox
                        x:Name="SeasonsBox"
                        Grid.Column="1"
                        Header="Seasons Owned"
                        PlaceholderText="5"
                        InputScope="Number" />

                    <TextBox
                        x:Name="EpisodesBox"
                        Grid.Column="2"
                        Header="Episodes Owned"
                        PlaceholderText="100"
                        InputScope="Number" />

                    <Button
                        x:Name="SaveShowButton"
                        Grid.Column="3"
                        Content="Add TV Show"
                        Padding="24,10"
                        VerticalAlignment="Bottom"
                        Click="SaveShow_Click" />

                    <Button
                        x:Name="CancelEditButton"
                        Grid.Column="4"
                        Content="Cancel"
                        Padding="18,10"
                        VerticalAlignment="Bottom"
                        Visibility="Collapsed"
                        Click="CancelEdit_Click" />
                </Grid>

                <InfoBar
                    x:Name="StatusInfoBar"
                    IsOpen="False"
                    IsClosable="True" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock
                x:Name="ShowCountText"
                Text="0 TV shows"
                FontSize="20"
                FontWeight="SemiBold" />

            <ListView
                x:Name="ShowsListView"
                Grid.Row="1"
                ItemsSource="{x:Bind Shows, Mode=OneWay}"
                SelectionMode="None">

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="12" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Text="{Binding Title}"
                                FontSize="18"
                                FontWeight="SemiBold"
                                VerticalAlignment="Center" />

                            <TextBlock
                                Grid.Column="1"
                                Text="{Binding Seasons}"
                                VerticalAlignment="Center" />

                            <TextBlock
                                Grid.Column="2"
                                Text="{Binding Episodes}"
                                VerticalAlignment="Center" />

                            <Button
                                Grid.Column="3"
                                Content="Edit"
                                Tag="{Binding}"
                                Click="EditShow_Click" />

                            <Button
                                Grid.Column="4"
                                Content="Delete"
                                Tag="{Binding}"
                                Click="DeleteShow_Click" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>