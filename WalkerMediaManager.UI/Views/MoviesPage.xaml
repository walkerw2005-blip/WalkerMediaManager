<Page
    x:Class="WalkerMediaManager.UI.Views.MoviesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WalkerMediaManager.UI.Controls">

    <Grid Padding="32" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock Text="Movies" Style="{ThemeResource TitleTextBlockStyle}" />
                <TextBlock Text="Browse and manage your movie collection." Style="{ThemeResource SubtitleTextBlockStyle}" />
            </StackPanel>
            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                <TextBlock x:Name="MovieCountText" Text="0 movies" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Right" />
                <TextBlock x:Name="VisibleCountText" Text="0 shown" Opacity="0.65" HorizontalAlignment="Right" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Padding="16" CornerRadius="10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <AutoSuggestBox x:Name="SearchBox" PlaceholderText="Search title, year, genre, director, or studio"
                                QueryIcon="Find" TextChanged="SearchBox_TextChanged" />
                <ComboBox x:Name="SortComboBox" Grid.Column="1" Header="Sort"
                          SelectionChanged="SortComboBox_SelectionChanged" SelectedIndex="0">
                    <ComboBoxItem Content="Title A–Z" Tag="TitleAscending" />
                    <ComboBoxItem Content="Title Z–A" Tag="TitleDescending" />
                    <ComboBoxItem Content="Newest first" Tag="YearDescending" />
                    <ComboBoxItem Content="Oldest first" Tag="YearAscending" />
                    <ComboBoxItem Content="Longest runtime" Tag="RuntimeDescending" />
                    <ComboBoxItem Content="Recently synced" Tag="RecentlySynced" />
                </ComboBox>
                <ToggleButton x:Name="GridViewToggle" Grid.Column="2" Content="Grid" IsChecked="True"
                              VerticalAlignment="Bottom" Click="GridViewToggle_Click" />
                <Button Grid.Column="3" Content="Add / Import" VerticalAlignment="Bottom" Click="ShowEditorButton_Click" />
            </Grid>
        </Border>

        <InfoBar x:Name="StatusInfoBar" Grid.Row="2" IsOpen="False" IsClosable="True" />

        <Grid Grid.Row="3">
            <GridView x:Name="MovieGridView" ItemsSource="{x:Bind DisplayMovies, Mode=OneWay}"
                      SelectionMode="None" IsItemClickEnabled="False">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="0" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <controls:MediaCard Movie="{Binding}"
                                            EditRequested="MediaCard_EditRequested"
                                            DeleteRequested="MediaCard_DeleteRequested" />
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <ListView x:Name="MovieListView" ItemsSource="{x:Bind DisplayMovies, Mode=OneWay}"
                      SelectionMode="None" Visibility="Collapsed">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,8" Padding="14" CornerRadius="8"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" FontSize="17" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Director}" Opacity="0.65" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding YearDisplay}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="{Binding RatingDisplay}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="3" Text="{Binding Genre}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                <Button Grid.Column="4" Content="Edit" Tag="{Binding}" Click="EditMovie_Click" />
                                <Button Grid.Column="5" Content="Delete" Tag="{Binding}" Click="DeleteMovie_Click" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <ContentDialog x:Name="MovieEditorDialog" Title="Add Movie" PrimaryButtonText="Save"
                       CloseButtonText="Cancel" PrimaryButtonClick="MovieEditorDialog_PrimaryButtonClick">
            <ScrollViewer MaxHeight="600">
                <StackPanel Spacing="12" MinWidth="520">
                    <TextBox x:Name="SpreadsheetPathBox" Header="Spreadsheet path (optional)" PlaceholderText="C:\Path\Walker Movie List.xlsx" />
                    <Button x:Name="ImportSpreadsheetButton" Content="Import Spreadsheet" HorizontalAlignment="Left"
                            Click="ImportSpreadsheetButton_Click" />
                    <ProgressRing x:Name="ImportProgressRing" IsActive="False" Visibility="Collapsed" />
                    <InfoBar x:Name="ImportInfoBar" IsOpen="False" IsClosable="True" />
                    <TextBlock Text="Movie details" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,0" />
                    <TextBox x:Name="TitleBox" Header="Title" />
                    <TextBox x:Name="YearBox" Header="Release year" InputScope="Number" />
                    <TextBox x:Name="RatingBox" Header="Rating" />
                    <TextBox x:Name="GenreBox" Header="Genre" />
                    <TextBox x:Name="DirectorBox" Header="Director" />
                </StackPanel>
            </ScrollViewer>
        </ContentDialog>
    </Grid>
</Page>
