<Page
    x:Class="WalkerMediaManager.UI.Views.MoviesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<Grid Padding="40" RowSpacing="24">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<StackPanel Spacing="6">
			<TextBlock
                Text="Movies"
                Style="{ThemeResource TitleTextBlockStyle}" />

			<TextBlock
                Text="Add and manage the movies you own."
                Style="{ThemeResource SubtitleTextBlockStyle}" />
		</StackPanel>

		<Border
            Grid.Row="1"
            Padding="20"
            CornerRadius="10"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1">

			<StackPanel Spacing="16">
				<TextBlock
                    x:Name="FormTitleText"
                    Text="Add Movie"
                    FontSize="22"
                    FontWeight="SemiBold" />

				<Grid ColumnSpacing="12" RowSpacing="12">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="2*" />
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="*" />
					</Grid.ColumnDefinitions>

					<TextBox
                        x:Name="TitleBox"
                        Header="Title"
                        PlaceholderText="Enter movie title" />

					<TextBox
                        x:Name="YearBox"
                        Grid.Column="1"
                        Header="Release Year"
                        PlaceholderText="1986"
                        InputScope="Number" />

					<TextBox
                        x:Name="RatingBox"
                        Grid.Column="2"
                        Header="Rating"
                        PlaceholderText="PG" />
				</Grid>

				<Grid ColumnSpacing="12">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>

					<TextBox
                        x:Name="GenreBox"
                        Header="Genre"
                        PlaceholderText="Action" />

					<TextBox
                        x:Name="DirectorBox"
                        Grid.Column="1"
                        Header="Director"
                        PlaceholderText="Director name" />

					<Button
                        x:Name="SaveMovieButton"
                        Grid.Column="2"
                        Content="Add Movie"
                        Padding="24,10"
                        VerticalAlignment="Bottom"
                        Click="SaveMovie_Click" />

					<Button
                        x:Name="CancelEditButton"
                        Grid.Column="3"
                        Content="Cancel"
                        Padding="18,10"
                        VerticalAlignment="Bottom"
                        Visibility="Collapsed"
                        Click="CancelEdit_Click" />
				</Grid>

				<InfoBar
                    x:Name="StatusInfoBar"
                    IsOpen="False"
                    IsClosable="True" />
			</StackPanel>
		</Border>

		<Grid Grid.Row="2" RowSpacing="12">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>

			<TextBlock
                x:Name="MovieCountText"
                Text="0 movies"
                FontSize="20"
                FontWeight="SemiBold" />

			<ListView
                x:Name="MoviesListView"
                Grid.Row="1"
                ItemsSource="{x:Bind Movies, Mode=OneWay}"
                SelectionMode="None">

				<ListView.ItemTemplate>
					<DataTemplate>
						<Grid Padding="12" ColumnSpacing="16">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="90" />
								<ColumnDefinition Width="90" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>

							<StackPanel>
								<TextBlock
                                    Text="{Binding Title}"
                                    FontSize="18"
                                    FontWeight="SemiBold" />

								<TextBlock
                                    Text="{Binding Director}"
                                    Opacity="0.65" />
							</StackPanel>

							<TextBlock
                                Grid.Column="1"
                                Text="{Binding ReleaseYear}"
                                VerticalAlignment="Center" />

							<TextBlock
                                Grid.Column="2"
                                Text="{Binding Rating}"
                                VerticalAlignment="Center" />

							<Button
                                Grid.Column="3"
                                Content="Edit"
                                Tag="{Binding}"
                                Click="EditMovie_Click" />

							<Button
                                Grid.Column="4"
                                Content="Delete"
                                Tag="{Binding}"
                                Click="DeleteMovie_Click" />
						</Grid>
					</DataTemplate>
				</ListView.ItemTemplate>
			</ListView>
		</Grid>
	</Grid>
</Page>