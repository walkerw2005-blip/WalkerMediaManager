<Page
    x:Class="WalkerMediaManager.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Padding="32" Spacing="20">
            <TextBlock Text="Walker Media Manager" FontSize="32" FontWeight="SemiBold"/>
            <TextBlock Text="Sprint 1: Plex connection and local database foundation" Opacity="0.7"/>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Padding="20" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel><TextBlock Text="Libraries"/><TextBlock x:Name="LibraryCountText" Text="0" FontSize="30" FontWeight="Bold"/></StackPanel>
                </Border>
                <Border Grid.Column="1" Padding="20" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel><TextBlock Text="Connection"/><TextBlock x:Name="ConnectionText" Text="Not configured" FontSize="20" FontWeight="SemiBold"/></StackPanel>
                </Border>
                <Border Grid.Column="2" Padding="20" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel><TextBlock Text="Database"/><TextBlock Text="Ready" FontSize="20" FontWeight="SemiBold"/></StackPanel>
                </Border>
            </Grid>

            <InfoBar IsOpen="True" Severity="Informational" Title="Next step"
                     Message="Open Plex Connection, enter your server URL and token, then test the connection."/>
            <InfoBar x:Name="UpdateInfoBar" IsOpen="False" Severity="Success" Title="Update available"/>
        </StackPanel>
    </ScrollViewer>
</Page>
